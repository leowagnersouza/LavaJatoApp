root = true

# Global defaults (Prettier-like consistency)
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4
max_line_length = 120

# Do not touch trailing whitespace in Markdown hard line-breaks
[*.md]
trim_trailing_whitespace = false
indent_size = 2
max_line_length = 100

# C#
[*.cs]
indent_size = 4
max_line_length = 120
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false
csharp_new_line_before_open_brace = all
csharp_indent_case_contents = true
csharp_indent_switch_labels = true
csharp_preserve_single_line_blocks = false
csharp_preserve_single_line_statements = false

# Prefer explicit, predictable style (low discussion)
csharp_style_var_for_built_in_types = false:suggestion
csharp_style_var_when_type_is_apparent = false:suggestion
csharp_style_var_elsewhere = false:suggestion
dotnet_style_predefined_type_for_locals_parameters_members = true:suggestion
dotnet_style_predefined_type_for_member_access = true:suggestion

# XAML / XML / project files
[*.{xaml,xml,csproj,props,targets,resx,plist,xcprivacy}]
indent_size = 4
max_line_length = 10

# Styles and Colors XAML files - ignore line breaks
[{Styles.xaml,Colors.xaml}]
max_line_length = 1200

# JSON
[*.json]
indent_size = 2
max_line_length = 120

# YAML
[*.{yml,yaml}]
indent_size = 2
max_line_length = 120

# Shell scripts
[*.sh]
indent_size = 2

# Generated files: keep analyzer noise down
[*.g.cs]
dotnet_analyzer_diagnostic.severity = none

[*.designer.cs]
dotnet_analyzer_diagnostic.severity = none

[**/{bin,obj}/**]
trim_trailing_whitespace = false
insert_final_newline = false

