<?xml
    version="1.0"
    encoding="UTF-8"?>

<Shell
    x:Class="LavaJatoApp.MAUI.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:LavaJatoApp.MAUI"
    xmlns:pages="clr-namespace:LavaJatoApp.MAUI.Pages"
    FlyoutBehavior="Disabled"
    Title="LavaJatoApp.MAUI">

    <TabBar>
        <ShellContent
            Title="Splash"
            ContentTemplate="{DataTemplate pages:SplashIntroPage}"
            Route="splash-intro" />

        <ShellContent
            Title="Login"
            ContentTemplate="{DataTemplate pages:LoginPage}"
            Route="login" />
    </TabBar>

</Shell>
