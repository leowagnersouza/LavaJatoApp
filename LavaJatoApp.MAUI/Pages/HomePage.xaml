<?xml
    version="1.0"
    encoding="utf-8"?>

<pages:BasePage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:LavaJatoApp.MAUI.Controls"
    xmlns:pages="clr-namespace:LavaJatoApp.MAUI.Pages"
    xmlns:viewmodels="clr-namespace:LavaJatoApp.MAUI.ViewModels"
    x:Class="LavaJatoApp.MAUI.Pages.HomePage"
    x:TypeArguments="viewmodels:HomeViewModel"
    x:DataType="viewmodels:HomeViewModel">
    <Grid
        RowDefinitions="Auto,*">
        <controls:FakeTitleBar Grid.Row="0" />

        <Grid
            Grid.Row="1"
            Padding="10">
            <VerticalStackLayout
                Spacing="8"
                HorizontalOptions="Center"
                VerticalOptions="Center">
                <Label
                    Text="Home"
                    FontSize="28"
                    FontAttributes="Bold"
                    HorizontalOptions="Center" />

                <Label
                    Text="Conteudo inicial da pagina Home"
                    FontSize="16"
                    HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</pages:BasePage>
