<?xml
    version="1.0"
    encoding="utf-8"?>

<pages:BasePage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:LavaJatoApp.MAUI.Pages"
    xmlns:viewmodels="clr-namespace:LavaJatoApp.MAUI.ViewModels"
    x:Class="LavaJatoApp.MAUI.Pages.DashboardPage"
    x:TypeArguments="viewmodels:DashboardViewModel"
    x:DataType="viewmodels:DashboardViewModel"
    Title="Dashboard">

    <Grid
        Padding="24">
        <VerticalStackLayout
            Spacing="8"
            HorizontalOptions="Center"
            VerticalOptions="Center">
            <Label
                Text="Dashboard"
                FontSize="28"
                FontAttributes="Bold"
                HorizontalOptions="Center" />

            <Label
                Text="Painel inicial de indicadores"
                FontSize="16"
                HorizontalOptions="Center" />
        </VerticalStackLayout>
    </Grid>

</pages:BasePage>
