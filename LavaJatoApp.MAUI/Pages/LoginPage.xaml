<?xml
    version="1.0"
    encoding="utf-8"?>

<pages:BasePage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:LavaJatoApp.MAUI.Pages"
    xmlns:viewmodels="clr-namespace:LavaJatoApp.MAUI.ViewModels"
    xmlns:controls="clr-namespace:LavaJatoApp.MAUI.Controls"
    x:TypeArguments="viewmodels:LoginViewModel"
    x:Class="LavaJatoApp.MAUI.Pages.LoginPage"
    x:DataType="viewmodels:LoginViewModel"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False"
    Title="Login">

    <Grid
        RowDefinitions="Auto,*">
        <VerticalStackLayout
            Grid.Row="0"
            Margin="30,40,30,10">
            <Image
                Source="logointerno.png"
                WidthRequest="299"
                HeightRequest="71"
                HorizontalOptions="Start"
                VerticalOptions="Center"
                Aspect="AspectFit"
                Margin="0,10,0,0" />
            <Label
                Text="Olá!"
                HorizontalOptions="Start"
                FontSize="15"
                Margin="3,70,0,5" />
            <Label
                Text="Informe o seu login e senha:"
                HorizontalOptions="Start"
                FontSize="15"
                Margin="3,0,0,5" />

            <controls:BorderedEntry
                Placeholder="Informe o seu email"
                Keyboard="Email" />

            <controls:BorderedEntry
                Margin="0,10,0,0"
                Placeholder="Informe a sua senha"
                IsPassword="True" />

        </VerticalStackLayout>
    </Grid>

</pages:BasePage>
